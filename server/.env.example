PORT=3001
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://postgres:password@localhost:5432/custom_charts
NODE_ENV=development

# ── Snowflake (optional) ────────────────────────────────────────────────────
# When set, the app connects to Snowflake instead of using mock in-memory data.
# The schema is auto-introspected and the Claude prompt is built dynamically.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
